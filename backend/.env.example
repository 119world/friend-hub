# Friend Hub backend API
# Copy this file to backend/.env and paste your real secret values.

PORT=8080
NODE_ENV=production

# Allowed frontend/admin URLs for CORS.
CLIENT_URL=https://friend-hub-pi.vercel.app
# Use the same frontend URL until the separate admin app is deployed.
ADMIN_URL=https://friend-hub-pi.vercel.app
# Optional comma-separated extra origins, for custom domains or a deployed admin app.
CORS_ORIGINS=https://friend-hub-pi.vercel.app

# Admin/partner default login. Keep these secret in Render only.
ADMIN_TOKEN=replace-with-long-random-admin-token
ADMIN_USERNAME=replace-with-admin-username
ADMIN_PASSWORD=replace-with-strong-admin-password
DEFAULT_PARTNER_LOGIN_ID=replace-with-partner-login-id
DEFAULT_PARTNER_PASSWORD=replace-with-partner-password
JWT_SECRET=change-this-long-random-jwt-secret

# Firebase Admin SDK service-account values.
# Get these from Firebase Console > Project settings > Service accounts > Generate new private key.
FIREBASE_PROJECT_ID=xxxx
FIRESTORE_ENABLED=true
FIREBASE_STORAGE_BUCKET=xxxx.appspot.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@xxxx.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_PRIVATE_KEY_WITH_N_SLASHES_HERE\n-----END PRIVATE KEY-----\n"

# Cloudinary media uploads. Recommended if Firebase Storage asks for billing.
CLOUDINARY_CLOUD_NAME=xxxx
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx

# Primary Razorpay account. Extra Razorpay/UPI accounts are added from Admin > Payment Accounts.
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=xxxx
RAZORPAY_WEBHOOK_SECRET=xxxx
RAZORPAY_FALLBACK_PAYMENT_URL=https://rzp.io/rzp/your-default-link
