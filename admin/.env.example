# Friend Hub admin frontend
# Copy this file to admin/.env and paste your real values.

# Same backend base URL. The admin app automatically adds /api.
VITE_API_BASE_URL=https://friend-hub-backend.onrender.com

# Optional exact API URL. Use this only if your API path is different.
# VITE_API_URL=https://friend-hub-backend.onrender.com/api

# Must match backend ADMIN_TOKEN.
VITE_ADMIN_TOKEN=change-this-long-admin-token
