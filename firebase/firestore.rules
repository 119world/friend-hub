rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isChatParticipant(chatId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow write: if false;
    }

    match /aiBots/{botId} {
      allow read: if true;
      allow write: if false;
    }

    match /chats/{chatId} {
      allow read: if isChatParticipant(chatId);
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() >= 2
        && request.resource.data.blocked == false;
      allow update: if isChatParticipant(chatId);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.type in ["text", "image", "video", "audio", "file"]
          && (!('text' in request.resource.data) || request.resource.data.text.size() <= 2000);
        allow update: if isChatParticipant(chatId);
        allow delete: if false;
      }
    }

    match /diamondWallets/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if false;
    }

    match /payments/{paymentId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /reports/{reportId} {
      allow create: if signedIn();
      allow read, update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /bankAccounts/{id} { allow read, write: if false; }
    match /paymentAccounts/{id} { allow read, write: if false; }
    match /partnerAccounts/{id} { allow read, write: if false; }
    match /apiKeys/{id} { allow read, write: if false; }
    match /appSettings/{id} { allow read: if true; allow write: if false; }
    match /mediaAssets/{id} { allow read: if true; allow write: if false; }
    match /offers/{id} { allow read: if true; allow write: if false; }
    match /autoReplies/{id} { allow read: if true; allow write: if false; }
    match /subscriptions/{id} { allow read: if signedIn() && resource.data.userId == request.auth.uid; allow write: if false; }
    match /callSessions/{id} { allow read: if signedIn() && request.auth.uid in resource.data.participants; allow write: if false; }
    match /adminLogs/{id} { allow read, write: if false; }
    match /replyTemplates/{id} { allow read: if true; allow write: if false; }
  }
}
